# ─────────────────────────────────────────────────────────────
# SOC Lab — .gitignore
# ─────────────────────────────────────────────────────────────

# ── Credentials — NEVER commit ───────────────────────────────
config/.env
.env

# ── Captured traffic files ────────────────────────────────────
logs/
*.pcap
*.csv

# ── Generated reports ─────────────────────────────────────────
alert.json
soc_report.json

# ── Python ───────────────────────────────────────────────────
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editors ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── others ────────────────────────────────────────────────────
Dev Docs/
tests/

AGENT_BRAIN.md