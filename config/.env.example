# ─────────────────────────────────────────────────────────────
# SOC Lab — Environment Variables Template
# ─────────────────────────────────────────────────────────────
#
# SETUP:
#   1. cp config/.env.example config/.env
#   2. Fill in your values below
#   3. Never commit config/.env — it is in .gitignore
#
# ─────────────────────────────────────────────────────────────

# ── Airia AI Platform (get from airia.com dashboard) ─────────
AIRIA_API_URL=https://api.airia.ai/v2/PipelineExecution/YOUR-PROJECT-ID-HERE
AIRIA_API_KEY=ak-YOUR-API-KEY-HERE

# ── Lab Network ───────────────────────────────────────────────
# Change these if your VMs use a different subnet
DESTINATION_IP=192.168.56.20
DESTINATION_HOST=Kali-SOC-Monitor

# ── Capture Settings ──────────────────────────────────────────
# Run 'ip addr' or 'tshark -D' to find your host-only interface
INTERFACE=eth1
CAPTURE_DURATION=100
THRESHOLD=40

# ── Paths (auto-detected if left empty, override if needed) ──
# Leave commented to use auto-detected relative paths
# DB_PATH=/home/YOUR-USER/soc-lab/database/soc_lab.db
# RULES_PATH=/home/YOUR-USER/soc-lab/config/detection_rules.yaml
# PCAP_FILE=/home/YOUR-USER/soc-lab/logs/traffic.pcap
# CSV_FILE=/home/YOUR-USER/soc-lab/logs/traffic.csv
# ALERT_FILE=/home/YOUR-USER/soc-lab/logs/alert.json

# ── Flask Dashboard ───────────────────────────────────────────
FLASK_PORT=5000
FLASK_HOST=0.0.0.0

# ── Wazuh Integration (Phase 3) ──────────────────────────────
# URL where Flask dashboard receives Wazuh alerts
# Used by custom-w2airia.py inside the Wazuh container
# Change IP if your Kali VM has a different address
FLASK_INGEST_URL=http://192.168.56.20:5000/api/alerts/ingest
