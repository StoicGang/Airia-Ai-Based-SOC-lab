# ─────────────────────────────────────────────────────────────
# SOC Lab — Environment Variables Template
# ─────────────────────────────────────────────────────────────
#
# SETUP INSTRUCTIONS:
#   1. Copy this file:   cp config/.env.example config/.env
#   2. Fill in your real values below
#   3. Never commit config/.env — it is in .gitignore
#   4. This file (.env.example) is safe to commit
#
# ─────────────────────────────────────────────────────────────

# ── Airia AI Platform (get from airia.com dashboard) ─────────
AIRIA_API_URL=https://api.airia.ai/v2/PipelineExecution/YOUR-PROJECT-ID-HERE
AIRIA_API_KEY=ak-YOUR-API-KEY-HERE

# ── Lab Network ───────────────────────────────────────────────
DESTINATION_IP=192.168.56.20
DESTINATION_HOST=Kali-SOC-Monitor

# ── Capture Settings ──────────────────────────────────────────
# Run 'tshark -D' to find your interface name or number
INTERFACE=eth0
CAPTURE_DURATION=100
THRESHOLD=40

# Database
DB_PATH=/home/kali/soc-lab/database/soc_lab.db

#Rules
RULES_PATH=/home/kali/soc-lab/config/detection_rules.yaml